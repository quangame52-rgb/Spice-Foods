{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product sold on the landing page",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "description": { "type": "string", "description": "Product description" },
        "price": { "type": "number", "description": "Product price" },
        "originalPrice": { "type": "number", "description": "Original price before discount" },
        "discountPercent": { "type": "number", "description": "Discount percentage" },
        "discountBadge": { "type": "string", "description": "Discount badge text (e.g., -20%)" },
        "promoText": { "type": "string", "description": "Promotional text (e.g., Buy 2 get 1 free)" },
        "image": { "type": "string", "description": "Product image URL" },
        "category": { "type": "string", "enum": ["seasoning", "dipping", "powder", "hotpot"], "description": "Product category" },
        "weight": { "type": "string", "description": "Product weight (optional)" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["name", "price", "image", "category"]
    },
    "User": {
      "title": "User",
      "description": "User profile and roles",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "orderCode": { "type": "string", "description": "Unique order code" },
        "customerName": { "type": "string", "description": "Customer name" },
        "customerPhone": { "type": "string", "description": "Customer phone" },
        "customerEmail": { "type": "string", "description": "Customer email" },
        "customerAddress": { "type": "string", "description": "Customer address" },
        "note": { "type": "string", "description": "Order note" },
        "productId": { "type": "string", "description": "ID of the ordered product" },
        "productName": { "type": "string", "description": "Name of the ordered product" },
        "productPrice": { "type": "number", "description": "Price of the ordered product" },
        "paymentMethod": { "type": "string", "enum": ["cod", "qr"], "description": "Payment method" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"], "description": "Order status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Order creation timestamp" }
      },
      "required": ["orderCode", "customerName", "customerPhone", "customerAddress", "productId", "productName", "productPrice", "paymentMethod", "status"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global site content like About Us and Contact Info",
      "type": "object",
      "properties": {
        "aboutUs": { "type": "string", "description": "About Us text" },
        "contactPhone": { "type": "string", "description": "Contact phone number" },
        "contactEmail": { "type": "string", "description": "Contact email address" },
        "contactAddress": { "type": "string", "description": "Contact physical address" },
        "heroTitle": { "type": "string", "description": "Hero section title" },
        "heroSubtitle": { "type": "string", "description": "Hero section subtitle" },
        "logo": { "type": "string", "description": "Brand logo URL" },
        "storyTitle": { "type": "string", "description": "Our Story section title" },
        "storyContent": { "type": "string", "description": "Our Story section content" },
        "storyImage": { "type": "string", "description": "Our Story section image URL" },
        "storyImages": { "type": "array", "items": { "type": "string" }, "description": "List of images for Our Story gallery" },
        "storyVideoUrl": { "type": "string", "description": "Video URL for Our Story (YouTube/Vimeo or direct)" },
        "storyMediaType": { "type": "string", "enum": ["image", "video", "gallery"], "description": "Type of media to display in Our Story" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/products": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/users": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "/orders": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "/site_settings": {
      "schema": "SiteSettings",
      "description": "Singleton collection for site settings"
    }
  }
}
